map $http_upgrade $connection_upgrade {
        default upgrade;
        ''      close;
}
server{
	server_name codemirror_proxy.cybergamma.group;
	include /etc/nginx/cgg_service_errors;
	location /{
		alias /home/aurel/gzod_site/codemirror_proxy.gzodp;
		include fastcgi.conf;
		fastcgi_pass unix:/run/php/php8.2-fpm.sock;
	}
	include /etc/nginx/cgg_ssl;
}
limit_req_zone $binary_remote_addr zone=onePerSecMakernight:10m rate=1r/s;
server {
	server_name leaderboard_makernight.cybergamma.group;
	include /etc/nginx/cgg_service_errors;
	index index.php;
	root /home/aurel/gzod_site/leaderboard_makernight/src;
	error_page 404 /404.php;
	location /{
		charset utf-8;
		try_files $uri $uri.php $uri.html $uri/index.php $uri/index.gzodp $uri/index.html =404;
		#fastcgi_intercept_errors on;
		fastcgi_pass unix:/run/php/apps-gzod01-fr.sock;
		fastcgi_index index.gzodp;
		fastcgi_param SCRIPT_FILENAME $document_root/$fastcgi_script_name;
		add_header Content-Type "$apps_gzod01_fr_content_type";
		include fastcgi_params;
		

	}
	location /httpCallBack{
		limit_req zone=onePerSecMakernight;
	}
	include /etc/nginx/cgg_ssl;
}
